    "kit": {
      "info": {
        "contact": {
          "name": "CheapShark API Documentation",
          "url": "https://apidocs.cheapshark.com/"
        },
        "description": "CheapShark is a price comparison website for digital PC Games, tracking prices across multiple stores including Steam, GreenManGaming, and Fanatical. The API provides developers with access to CheapShark pricing data to integrate into their own applications or websites.",
        "servers": [
          {
            "description": "CheapShark API Server",
            "url": "https://www.cheapshark.com/api/1.0"
          }
        ],
        "title": "CheapShark API",
        "version": "1.0.0",
        "tagline": "Compare digital PC game prices across Steam, GreenManGaming, Fanatical and other major stores",
        "homepage": "https://www.cheapshark.com/",
        "docs_url": "https://apidocs.cheapshark.com/",
        "about_md": "[CheapShark](https://www.cheapshark.com/) is a price comparison site for digital PC games. The public API exposes the same catalogue of deals, games and stores that powers the website, so you can build trackers, browser extensions, bots and dashboards on top of it.\n\nWhat you get from the API:\n- Current and historical deals across multiple digital storefronts (Steam, GreenManGaming, Fanatical and others)\n- Game metadata with cross-store price information\n- The list of stores CheapShark tracks, including store IDs used elsewhere in the API\n- Price-drop alert subscriptions tied to an email address\n\nOperational notes: the API is served from `https://www.cheapshark.com/api/1.0` and has CORS enabled, so it can be called directly from browser apps. No API key or authentication is documented.",
        "entity_desc": {
          "alert": "Email-based price alert subscriptions that notify a user when a tracked game drops to a target price.",
          "deal": "An individual store listing for a game at a specific price, including sale price, retail price, savings and the store it comes from.",
          "game": "A PC game record with title, cover art and the set of deals currently available for it across tracked stores.",
          "store": "A digital storefront tracked by CheapShark (e.g. Steam, GreenManGaming, Fanatical), with the store ID used to reference it in deal and game responses."
        },
        "auth": false
      },
      "config": {
        "auth": {
          "prefix": "Bearer"
        },
        "headers": {
          "content-type": "application/json"
        },
        "docs_order": [
          "ts",
          "py",
          "php",
          "go",
          "rb",
          "lua"
        ]
      },
